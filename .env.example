# ============================================
# Grid Trading Bot - Environment Configuration
# ============================================

# Required: Private key for the trading wallet (with 0x prefix)
PRIVATE_KEY=0x...

# Required: RPC URL for blockchain connection
RPC_URL=https://...

# Required: Chain ID (4663 for Robinhood, 8453 for Base, 1 for Mainnet)
CHAIN_ID=4663

# Required: 0x API key from https://0x.org/
ZEROX_API_KEY=...

# Trading Configuration
# ---------------------

# Token to trade (base token address)
TOKEN_ADDRESS=0x...

# Token symbol for logging
TOKEN_SYMBOL=TOKEN

# Grid spacing percentage (default: 5%)
GRID_SPACING_PERCENT=5.0

# Maximum number of grid positions (Robinhood: 20, Mainnet: 10)
MAX_POSITIONS=20

# Minimum profit percentage required before selling (default: 1.5%)
MIN_PROFIT_PERCENT=1.5

# Initial buy amount in WETH (for first position)
INITIAL_BUY_AMOUNT=0.01

# Slippage tolerance percentage (default: 1%)
SLIPPAGE_TOLERANCE=1.0

# Bank Configuration
# ------------------

# USDG token address for profit banking
USDG_ADDRESS=0x...

# Percentage of profits to bank to USDG (0-100, default: 50)
BANK_PERCENTAGE=50.0

# Bot Behavior
# ------------

# Poll interval in seconds (default: 30)
POLL_INTERVAL_SECONDS=30

# Enable anti-MEV jitter on quotes (default: true)
ANTI_MEV_JITTER=true

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# State file path for persisting positions
STATE_FILE=./data/positions.json

# Gridless Trading Mode
# ---------------------
# Enable gridless position-based trading (no fixed grid levels)
USE_GRIDLESS=false

# P&L threshold to trigger new buy (default: -10.0, means buy when top position is -10% or worse)
GRIDLESS_BUY_THRESHOLD=-10.0

# P&L threshold to trigger sell (default: 5.0, means sell at +5% profit)
GRIDLESS_SELL_THRESHOLD=5.0

# Stoploss threshold (default: -25.0, sell immediately if position drops to -25%)
GRIDLESS_STOPLOSS_THRESHOLD=-25.0

# Enable stoploss sells (default: false)
GRIDLESS_STOPLOSS_ENABLED=false

# Leading Edge Mode (default: false)
# When enabled with only 1 position: buy at 50% of sell threshold (e.g., +2.5% if sell=5%)
# This keeps you positioned on the leading edge during run-ups
GRIDLESS_LEADING_EDGE=false